---
import { about } from '../../consts';
---

<section id="about" class="relative z-10 pt-32 pb-24 px-6">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="font-heading text-3xl text-brand-white mb-8 reveal-up">À propos</h2>

    <p class="text-brand-gray-400 text-sm md:text-base leading-relaxed reveal-up reveal-up-delay-1 max-w-xl mx-auto">
      <span class="font-bold italic text-brand-white">{about.intro.split('.')[0] + '.'}</span>
      {about.intro.slice(about.intro.indexOf('.') + 1)}
    </p>

    <div class="mt-12 flex justify-center gap-12 reveal-up reveal-up-delay-2">
      <div class="text-center">
        <span class="font-heading text-3xl text-brand-white">+50</span>
        <p class="text-brand-gray-700 text-[10px] uppercase tracking-widest mt-1">Projets livrés</p>
      </div>
      <div class="text-center">
        <span class="font-heading text-3xl text-brand-white">3</span>
        <p class="text-brand-gray-700 text-[10px] uppercase tracking-widest mt-1">Années d'expérience</p>
      </div>
    </div>

    <div class="mt-12 reveal-up reveal-up-delay-3">
      <p class="text-brand-gray-700 text-[10px] uppercase tracking-widest mb-3">Stack</p>
      <div class="flex flex-wrap justify-center gap-2">
        {about.stack.map((tool) => (
          <span class="px-3 py-1 text-[10px] uppercase tracking-wider border border-brand-gray-800 rounded-full text-brand-gray-400 hover:text-brand-white hover:scale-110 transition-all duration-300">
            {tool}
          </span>
        ))}
      </div>
    </div>

    <div class="mt-8 reveal-up reveal-up-delay-4">
      <p class="text-brand-gray-700 text-[10px] uppercase tracking-widest mb-3">Clients</p>
      <div class="flex flex-wrap justify-center gap-2">
        {about.clients.map((client) => (
          <span class="px-3 py-1 text-[10px] uppercase tracking-wider border border-brand-gray-800 rounded-full text-brand-gray-400 hover:text-brand-white hover:scale-110 transition-all duration-300">
            {client}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
