---
import { site } from '../../consts';
---

<section id="contact" class="relative z-10 tilt-card bg-brand-dark/70 backdrop-blur-xl border border-white/[0.07] rounded-[40px] shadow-xl shadow-[inset_0_0_1px_1px_rgba(255,255,255,0.04),inset_0_0_30px_-8px_rgba(255,255,255,0.06)] px-6 md:px-10 py-6 md:py-8 relative overflow-hidden text-center mx-auto max-w-sm">

  <h2 id="magnet-contact" class="font-heading text-lg md:text-xl leading-none text-brand-white inline-block cursor-default mb-4">
    <span class="magnet-letter">C</span>
    <span class="magnet-letter">o</span>
    <span class="magnet-letter">n</span>
    <span class="magnet-letter">t</span>
    <span class="magnet-letter">a</span>
    <span class="magnet-letter">c</span>
    <span class="magnet-letter">t</span>
  </h2>

  <div class="flex flex-col items-center justify-center gap-3">
    <a href="mailto:${site.email}" target="_blank" rel="noopener" class="group/link inline-flex items-center gap-3 px-6 py-2.5 text-xs uppercase tracking-wider border border-brand-gray-700/60 rounded-full text-brand-gray-200 hover:text-brand-white hover:border-brand-accent hover:bg-brand-accent/10 hover:scale-105 transition-all duration-300">
      <svg class="w-4 h-4 shrink-0 text-brand-gray-400 group-hover/link:text-brand-accent transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
      <span>Email</span>
    </a>
    <a href={site.socials.instagram} target="_blank" rel="noopener" class="group/link inline-flex items-center gap-3 px-6 py-2.5 text-xs uppercase tracking-wider border border-brand-gray-700/60 rounded-full text-brand-gray-200 hover:text-brand-white hover:border-brand-accent hover:bg-brand-accent/10 hover:scale-105 transition-all duration-300">
      <svg class="w-4 h-4 shrink-0 text-brand-gray-400 group-hover/link:text-brand-accent transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <rect x="2" y="2" width="20" height="20" rx="5" />
        <circle cx="12" cy="12" r="5" />
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
      </svg>
      <span>Instagram</span>
    </a>
    <a href={site.socials.linkedin} target="_blank" rel="noopener" class="group/link inline-flex items-center gap-3 px-6 py-2.5 text-xs uppercase tracking-wider border border-brand-gray-700/60 rounded-full text-brand-gray-200 hover:text-brand-white hover:border-brand-accent hover:bg-brand-accent/10 hover:scale-105 transition-all duration-300">
      <svg class="w-4 h-4 shrink-0 text-brand-gray-400 group-hover/link:text-brand-accent transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <rect x="2" y="2" width="20" height="20" rx="3" />
        <path d="M7 10v7" stroke-linecap="round" />
        <circle cx="7" cy="7" r="1.2" fill="currentColor" stroke="none" />
        <path d="M11 17v-4.5a2 2 0 014 0V17" stroke-linecap="round" />
      </svg>
      <span>LinkedIn</span>
    </a>
  </div>
</section>
