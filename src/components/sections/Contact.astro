---
import { site } from '../../consts';
---

<section id="contact" class="relative z-10 pt-8 md:pt-10">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <!-- Email -->
    <a href={`mailto:${site.email}`} target="_blank" rel="noopener" class="tilt-card group relative flex flex-col items-center justify-center gap-3 bg-brand-dark/70 backdrop-blur-xl border border-white/[0.07] rounded-[40px] shadow-xl shadow-[inset_0_0_1px_1px_rgba(255,255,255,0.04)] px-5 py-10 md:py-12 text-center overflow-hidden transition-all duration-300 hover:border-brand-accent/40 hover:shadow-brand-accent/10">
      <!-- Particles -->
      <span class="absolute w-1.5 h-1.5 rounded-full bg-brand-accent/20 top-[15%] left-[20%]"></span>
      <span class="absolute w-1 h-1 rounded-full bg-brand-accent/15 top-[30%] right-[15%]"></span>
      <span class="absolute w-2 h-2 rounded-full bg-brand-accent/10 bottom-[20%] left-[30%]"></span>
      <span class="absolute w-1 h-1 rounded-full bg-brand-white/10 bottom-[35%] right-[25%]"></span>
      <span class="absolute w-1.5 h-1.5 rounded-full bg-brand-accent/15 top-[60%] left-[10%]"></span>

      <span class="relative z-10 flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full border border-white/[0.10] bg-brand-dark/40 text-brand-gray-400 group-hover:border-brand-accent/50 group-hover:text-brand-accent group-hover:bg-brand-accent/10 transition-all duration-300">
        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
      </span>
      <span class="relative z-10 text-brand-gray-400 text-xs uppercase tracking-widest group-hover:text-brand-white transition-colors duration-300">Email</span>
    </a>

    <!-- Instagram -->
    <a href={site.socials.instagram} target="_blank" rel="noopener" class="tilt-card group relative flex flex-col items-center justify-center gap-3 bg-brand-dark/70 backdrop-blur-xl border border-white/[0.07] rounded-[40px] shadow-xl shadow-[inset_0_0_1px_1px_rgba(255,255,255,0.04)] px-5 py-10 md:py-12 text-center overflow-hidden transition-all duration-300 hover:border-brand-accent/40 hover:shadow-brand-accent/10">
      <!-- Particles -->
      <span class="absolute w-1.5 h-1.5 rounded-full bg-brand-accent/20 top-[18%] right-[25%]"></span>
      <span class="absolute w-1 h-1 rounded-full bg-brand-accent/15 top-[45%] left-[12%]"></span>
      <span class="absolute w-2 h-2 rounded-full bg-brand-accent/10 bottom-[15%] right-[20%]"></span>
      <span class="absolute w-1 h-1 rounded-full bg-brand-white/10 bottom-[40%] left-[30%]"></span>
      <span class="absolute w-1.5 h-1.5 rounded-full bg-brand-accent/15 top-[70%] right-[10%]"></span>

      <span class="relative z-10 flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full border border-white/[0.10] bg-brand-dark/40 text-brand-gray-400 group-hover:border-brand-accent/50 group-hover:text-brand-accent group-hover:bg-brand-accent/10 transition-all duration-300">
        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="2" y="2" width="20" height="20" rx="5" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
        </svg>
      </span>
      <span class="relative z-10 text-brand-gray-400 text-xs uppercase tracking-widest group-hover:text-brand-white transition-colors duration-300">Instagram</span>
    </a>

    <!-- LinkedIn -->
    <a href={site.socials.linkedin} target="_blank" rel="noopener" class="tilt-card group relative flex flex-col items-center justify-center gap-3 bg-brand-dark/70 backdrop-blur-xl border border-white/[0.07] rounded-[40px] shadow-xl shadow-[inset_0_0_1px_1px_rgba(255,255,255,0.04)] px-5 py-10 md:py-12 text-center overflow-hidden transition-all duration-300 hover:border-brand-accent/40 hover:shadow-brand-accent/10">
      <!-- Particles -->
      <span class="absolute w-1.5 h-1.5 rounded-full bg-brand-accent/20 top-[12%] left-[30%]"></span>
      <span class="absolute w-1 h-1 rounded-full bg-brand-accent/15 top-[55%] right-[18%]"></span>
      <span class="absolute w-2 h-2 rounded-full bg-brand-accent/10 bottom-[25%] left-[15%]"></span>
      <span class="absolute w-1 h-1 rounded-full bg-brand-white/10 bottom-[30%] right-[30%]"></span>
      <span class="absolute w-1.5 h-1.5 rounded-full bg-brand-accent/15 top-[25%] right-[35%]"></span>

      <span class="relative z-10 flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full border border-white/[0.10] bg-brand-dark/40 text-brand-gray-400 group-hover:border-brand-accent/50 group-hover:text-brand-accent group-hover:bg-brand-accent/10 transition-all duration-300">
        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="2" y="2" width="20" height="20" rx="3" />
          <path d="M7 10v7" stroke-linecap="round" />
          <circle cx="7" cy="7" r="1.2" fill="currentColor" stroke="none" />
          <path d="M11 17v-4.5a2 2 0 014 0V17" stroke-linecap="round" />
        </svg>
      </span>
      <span class="relative z-10 text-brand-gray-400 text-xs uppercase tracking-widest group-hover:text-brand-white transition-colors duration-300">LinkedIn</span>
    </a>
  </div>
</section>
