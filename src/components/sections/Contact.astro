---
import { site } from '../../consts';
---

<section id="contact" class="relative z-10 tilt-card bg-brand-dark/70 backdrop-blur-xl border border-white/[0.07] rounded-[40px] shadow-xl shadow-[inset_0_0_1px_1px_rgba(255,255,255,0.04),inset_0_0_30px_-8px_rgba(255,255,255,0.06)] px-6 md:px-10 py-7 md:py-9 relative text-center">

  <!-- Floating particles (★ ✦) -->
  <span class="card-particle" style="font-size:8px;color:#7C3AED;top:18%;right:8%;animation-duration:8s;">✦</span>
  <span class="card-particle" style="font-size:6px;color:rgba(255,255,255,0.2);bottom:30%;left:6%;animation-duration:10s;animation-delay:1.2s;">✧</span>
  <span class="card-particle" style="font-size:5px;color:#9B6DFF;top:60%;right:4%;animation-duration:7s;animation-delay:0.5s;">★</span>
  <span class="card-particle" style="font-size:7px;color:rgba(124,58,237,0.3);bottom:8%;right:18%;animation-duration:9s;animation-delay:2s;">✦</span>

  <h2 id="magnet-contact" class="font-heading text-2xl md:text-3xl leading-none text-brand-white cursor-default reveal-up">
    Contact
  </h2>
  <div class="w-10 h-px bg-brand-white/20 mx-auto mt-3 mb-4"></div>
  <p class="text-brand-gray-400 text-xs md:text-sm max-w-xs mx-auto reveal-up reveal-up-delay-1" data-i18n="contact.subtitle">
    Un projet, une collaboration ? Discutons-en !
  </p>

  <!-- Services mini-pills -->
  <div class="flex flex-wrap items-center justify-center gap-2 mt-4 reveal-up reveal-up-delay-2">
    <span class="px-2.5 py-1 text-[11px] md:text-xs uppercase tracking-wider border border-brand-gray-700/40 rounded-full text-brand-gray-300 hover:text-brand-accent hover:border-brand-accent hover:brightness-125 hover:-translate-y-0.5 hover:shadow-[0_0_16px_-4px_rgba(124,58,237,0.3)] transition-all duration-300">🎬 Montage</span>
    <span class="px-2.5 py-1 text-[11px] md:text-xs uppercase tracking-wider border border-brand-gray-700/40 rounded-full text-brand-gray-300 hover:text-brand-accent hover:border-brand-accent hover:brightness-125 hover:-translate-y-0.5 hover:shadow-[0_0_16px_-4px_rgba(124,58,237,0.3)] transition-all duration-300">✨ Motion</span>
    <span class="px-2.5 py-1 text-[11px] md:text-xs uppercase tracking-wider border border-brand-gray-700/40 rounded-full text-brand-gray-300 hover:text-brand-accent hover:border-brand-accent hover:brightness-125 hover:-translate-y-0.5 hover:shadow-[0_0_16px_-4px_rgba(124,58,237,0.3)] transition-all duration-300">🎧 Sound</span>
    <span class="px-2.5 py-1 text-[11px] md:text-xs uppercase tracking-wider border border-brand-gray-700/40 rounded-full text-brand-gray-300 hover:text-brand-accent hover:border-brand-accent hover:brightness-125 hover:-translate-y-0.5 hover:shadow-[0_0_16px_-4px_rgba(124,58,237,0.3)] transition-all duration-300">🎨 Color</span>
  </div>

  <div class="flex flex-col items-center justify-center gap-3 mt-5 reveal-up reveal-up-delay-3">
    <a href={`mailto:${site.email}`} target="_blank" rel="noopener" class="group/link flex w-full items-center justify-center gap-3 px-8 py-3 text-sm tracking-wider border border-brand-gray-700/60 rounded-full text-brand-gray-200 hover:text-white hover:border-white hover:bg-white/10 hover:shadow-[0_0_24px_-4px_rgba(255,255,255,0.25)] hover:scale-105 transition-all duration-300">
      <svg class="w-4 h-4 shrink-0 text-brand-gray-400 group-hover/link:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
      <span>Email</span>
    </a>
    <a href={site.socials.instagram} target="_blank" rel="noopener" class="group/link flex w-full items-center justify-center gap-3 px-8 py-3 text-sm tracking-wider border border-brand-gray-700/60 rounded-full text-brand-gray-200 hover:text-pink-300 hover:border-pink-500 hover:bg-pink-500/10 hover:shadow-[0_0_24px_-4px_rgba(236,72,153,0.4)] hover:scale-105 transition-all duration-300">
      <svg class="w-4 h-4 shrink-0 text-brand-gray-400 group-hover/link:text-pink-400 transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <rect x="2" y="2" width="20" height="20" rx="5" />
        <circle cx="12" cy="12" r="5" />
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
      </svg>
      <span>Instagram</span>
    </a>
    <a href={site.socials.linkedin} target="_blank" rel="noopener" class="group/link flex w-full items-center justify-center gap-3 px-8 py-3 text-sm tracking-wider border border-brand-gray-700/60 rounded-full text-brand-gray-200 hover:text-blue-300 hover:border-blue-600 hover:bg-blue-600/10 hover:shadow-[0_0_24px_-4px_rgba(37,99,235,0.4)] hover:scale-105 transition-all duration-300">
      <svg class="w-4 h-4 shrink-0 text-brand-gray-400 group-hover/link:text-blue-400 transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <rect x="2" y="2" width="20" height="20" rx="3" />
        <path d="M7 10v7" stroke-linecap="round" />
        <circle cx="7" cy="7" r="1.2" fill="currentColor" stroke="none" />
        <path d="M11 17v-4.5a2 2 0 014 0V17" stroke-linecap="round" />
      </svg>
      <span>LinkedIn</span>
    </a>
  </div>

  <!-- Contact info supplémentaire -->
  <div class="mt-6 pt-5 border-t border-white/[0.07] w-full reveal-up reveal-up-delay-4">
    <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-xs text-brand-gray-400">
      <a href={`mailto:${site.email}`} class="hover:text-brand-accent transition-colors">
        {site.email}
      </a>
      <span class="text-brand-gray-700 select-none">·</span>
      <span>📍 Lyon, France</span>
    </div>
  </div>
  <p class="mt-3 text-[12px] text-brand-gray-600 reveal-up reveal-up-delay-5">
    <span class="uppercase tracking-[0.2em]" data-i18n="contact.responseTime">Réponse sous 24h</span>
    <span class="normal-case" data-i18n="contact.responseTimeSuffix"> (sauf si je monte)</span>
  </p>
</section>
