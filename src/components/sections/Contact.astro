---
import { site } from '../../consts';
---

<section id="contact" class="relative z-10 pt-8 md:pt-10">
  <div class="bg-brand-dark/70 backdrop-blur-xl border border-white/[0.07] rounded-[40px] shadow-xl shadow-[inset_0_0_1px_1px_rgba(255,255,255,0.04)] px-6 md:px-10 py-5 md:py-6 relative overflow-hidden">
    <p class="text-center text-[10px] uppercase tracking-widest text-brand-gray-500 mb-4 md:mb-5" data-i18n="contact.title">Contact</p>
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 md:gap-0">
      <!-- Email -->
      <a href={`mailto:${site.email}`} target="_blank" rel="noopener" class="group flex items-center gap-3 md:gap-4 text-brand-gray-400 hover:text-brand-white transition-colors duration-300">
        <svg class="w-5 h-5 md:w-5 md:h-5 shrink-0 text-brand-gray-400 group-hover:text-brand-accent transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <span class="flex flex-col">
          <span class="text-xs uppercase tracking-widest font-medium">Email</span>
          <span class="text-[11px] text-brand-gray-500 group-hover:text-brand-gray-400 transition-colors duration-300">{site.email}</span>
        </span>
      </a>

      <!-- Instagram -->
      <a href={site.socials.instagram} target="_blank" rel="noopener" class="group flex items-center gap-3 md:gap-4 text-brand-gray-400 hover:text-brand-white transition-colors duration-300">
        <svg class="w-5 h-5 md:w-5 md:h-5 shrink-0 text-brand-gray-400 group-hover:text-brand-accent transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="2" y="2" width="20" height="20" rx="5" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
        </svg>
        <span class="flex flex-col">
          <span class="text-xs uppercase tracking-widest font-medium">Instagram</span>
          <span class="text-[11px] text-brand-gray-500 group-hover:text-brand-gray-400 transition-colors duration-300">{site.socials.instagram.replace('https://www.instagram.com/', '@')}</span>
        </span>
      </a>

      <!-- LinkedIn -->
      <a href={site.socials.linkedin} target="_blank" rel="noopener" class="group flex items-center gap-3 md:gap-4 text-brand-gray-400 hover:text-brand-white transition-colors duration-300">
        <svg class="w-5 h-5 md:w-5 md:h-5 shrink-0 text-brand-gray-400 group-hover:text-brand-accent transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="2" y="2" width="20" height="20" rx="3" />
          <path d="M7 10v7" stroke-linecap="round" />
          <circle cx="7" cy="7" r="1.2" fill="currentColor" stroke="none" />
          <path d="M11 17v-4.5a2 2 0 014 0V17" stroke-linecap="round" />
        </svg>
        <span class="flex flex-col">
          <span class="text-xs uppercase tracking-widest font-medium">LinkedIn</span>
          <span class="text-[11px] text-brand-gray-500 group-hover:text-brand-gray-400 transition-colors duration-300">Anthony Vuillerot</span>
        </span>
      </a>
    </div>
  </div>
</section>
