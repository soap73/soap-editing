---
import { site } from '../../consts';
---

<header class="relative z-10 px-6 pt-8 pb-2 md:pt-10 md:pb-4">
  <h1 class="font-heading font-bold text-5xl sm:text-6xl md:text-7xl leading-none reveal-up visible">
    <span class="text-brand-white italic">Soap</span>{' '}
    <span class="text-brand-accent not-italic">Editing</span>
  </h1>
  <p class="text-brand-gray-400 text-sm md:text-base mt-4 md:mt-6 mb-[50px] leading-relaxed reveal-up reveal-up-delay-1 visible">
    {site.tagline}
  </p>
</header>
