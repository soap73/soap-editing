<header class="relative z-10 px-4 md:px-6 pt-8 pb-2 md:pt-10 md:pb-4 text-center">
  <h1 class="font-heading text-4xl sm:text-5xl md:text-7xl leading-none text-glow-white magnet-title" id="magnet-title">
    <span class="text-brand-white italic font-normal hero-word magnet-word" id="magnet-soap" style="animation-delay: 0.2s">
      <span class="magnet-letter">S</span><span class="magnet-letter">o</span><span class="magnet-letter">a</span><span class="magnet-letter">p</span>
    </span>{' '}
    <span class="text-brand-accent not-italic font-bold hero-word magnet-word" id="magnet-edit" style="animation-delay: 0.6s; text-shadow: 0 0 20px rgba(124,58,237,0.5), 0 0 40px rgba(124,58,237,0.2)">
      <span class="magnet-letter">E</span><span class="magnet-letter">d</span><span class="magnet-letter">i</span><span class="magnet-letter">t</span>
    </span>
  </h1>
  <p class="text-brand-gray-400 text-sm md:text-base mt-4 md:mt-6 leading-relaxed hero-word" style="animation-delay: 1.1s">
    <span
      id="tagline-bubble"
      class="tagline-bubble inline-block px-4 py-1.5 text-[11px] uppercase tracking-widest border rounded-full transition-all duration-300 border-brand-accent/30 text-brand-accent bg-brand-accent/5 hover:border-brand-accent hover:scale-110 hover:bg-brand-accent/10 whitespace-nowrap"
      data-i18n="taglineBubbles"
    >Monteur Vidéo</span>
  </p>
</header>

<script>
  const title = document.getElementById('magnet-title') as HTMLElement | null;
  if (title) {
    const letters = title.querySelectorAll<HTMLElement>('.magnet-letter');
    const strength = 20;

    const startBounce = () => {
      letters.forEach((l, i) => {
        l.style.animation = 'letter-bounce 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both';
        l.style.animationDelay = `${i * 0.06}s`;
      });

      // Attach magnet after bounce animation ends
      const lastDelay = (letters.length - 1) * 0.06;
      const animDuration = 0.5;
      const magnetDelay = (lastDelay + animDuration) * 1000 + 300;

      setTimeout(() => {
        letters.forEach((l) => { l.style.animation = 'none'; });

        title.addEventListener('mousemove', (e) => {
          const rect = title.getBoundingClientRect();
          const cx = e.clientX - rect.left;
          const cy = e.clientY - rect.top;

          letters.forEach((letter) => {
            const lr = letter.getBoundingClientRect();
            const lx = lr.left + lr.width / 2 - rect.left;
            const ly = lr.top + lr.height / 2 - rect.top;

            const dx = cx - lx;
            const dy = cy - ly;
            const dist = Math.sqrt(dx * dx + dy * dy);
            const radius = 120;

            if (dist < radius) {
              const force = (1 - dist / radius) * strength;
              const tx = (dx / dist) * -force;
              const ty = (dy / dist) * -force * 0.5;
              const rot = (dx / dist) * force * 0.15;
              letter.style.transform = `translate(${tx}px, ${ty}px) rotate(${rot}deg)`;
              letter.style.transition = 'transform 0.12s ease-out';
            } else {
              letter.style.transform = 'translate(0, 0) rotate(0deg)';
              letter.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
            }
          });
        });

        title.addEventListener('mouseleave', () => {
          letters.forEach((letter) => {
            letter.style.transform = 'translate(0, 0) rotate(0deg)';
            letter.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
          });
        });
      }, magnetDelay);
    };

    // Wait for preloader to finish
    const preloader = document.getElementById('preloader');
    if (preloader) {
      let started = false;
      const observer = new MutationObserver(() => {
        if (preloader.classList.contains('done') && !started) {
          started = true;
          observer.disconnect();
          startBounce();
        }
      });
      observer.observe(preloader, { attributes: true, attributeFilter: ['class'] });
      setTimeout(() => {
        if (!started) {
          started = true;
          observer.disconnect();
          startBounce();
        }
      }, 2500);
    } else {
      startBounce();
    }
  }
</script>
