---
import { getCollection } from 'astro:content';
import { categories } from '../../consts';

const projects = await getCollection('projects');
const sorted = projects
  .map((p) => ({ ...p.data, id: p.id }))
  .sort((a, b) => a.order - b.order);

const firstProject = sorted[0];

function ytThumb(id: string, size = 'hqdefault') {
  if (import.meta.env.DEV) {
    return `https://img.youtube.com/vi/${id}/${size}.jpg`;
  }
  return `/yt-thumb/${id}?size=${size}`;
}

function thumbnailUrl(project: typeof sorted[number]) {
  if (project.youtubeId) {
    return ytThumb(project.youtubeId);
  }
  if (project.vimeoId) {
    return project.thumbnail || '/placeholder-thumb.webp';
  }
  return project.thumbnail || '/placeholder-thumb.webp';
}

function thumbnailSrcset(youtubeId: string) {
  return `${ytThumb(youtubeId, 'mqdefault')} 320w, ${ytThumb(youtubeId)} 480w, ${ytThumb(youtubeId, 'sddefault')} 640w`;
}

function posterUrl(preview: string) {
  return preview.replace(/\.(webm|mp4|mov)$/i, '-poster.webp');
}

function firstProjectThumb() {
  if (firstProject.preview && /\.(mp4|webm|mov)$/i.test(firstProject.preview)) {
    return posterUrl(firstProject.preview);
  }
  return thumbnailUrl(firstProject);
}

function extractYoutubeId(url: string): string | null {
  const patterns = [
    /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/shorts\/)([a-zA-Z0-9_-]{11})/,
  ];
  for (const p of patterns) {
    const m = url.match(p);
    if (m) return m[1];
  }
  return null;
}

function extractVimeoId(url: string): string | null {
  const m = url.match(/vimeo\.com\/(\d+)/);
  return m ? m[1] : null;
}

function resolveVideoIds(project: typeof sorted[number]) {
  let youtubeId = project.youtubeId || '';
  let vimeoId = project.vimeoId || '';
  if (!youtubeId && !vimeoId && project.videoUrl) {
    youtubeId = extractYoutubeId(project.videoUrl) || '';
    if (!youtubeId) vimeoId = extractVimeoId(project.videoUrl) || '';
  }
  return { youtubeId, vimeoId };
}

function aspectClass(ratio: string) {
  switch (ratio) {
    case '9:16': return 'aspect-[9/16]';
    case '1:1': return 'aspect-square';
    default: return 'aspect-video';
  }
}

---

<link rel="preload" as="image" href={firstProjectThumb()} fetchpriority="high" />

<section id="projects" class="relative z-10 w-full">
  <!-- Category filters -->
  <div class="flex justify-start px-4 md:px-6 pb-6 md:pb-8 reveal-up" id="category-filters-wrapper">
    <div class="glow-card bg-brand-dark/60 backdrop-blur-2xl border border-white/20 rounded-[100px] shadow-2xl shadow-[inset_0_0_30px_-8px_rgba(255,255,255,0.07)] px-5 md:px-6 py-2 relative overflow-hidden">
      <div class="filters-fade filters-fade-left"></div>
      <div class="filters-fade filters-fade-right"></div>
      <div class="overflow-x-auto py-1" style="-ms-overflow-style:none;scrollbar-width:none" id="category-filters">
        <div class="flex flex-nowrap justify-start gap-3">
        {categories.map((cat) => (
          <button
            class="cat-btn px-3 md:px-4 py-1.5 text-[10px] md:text-[11px] uppercase tracking-widest border rounded-full transition-all duration-300 border-brand-white/10 text-brand-gray-400 hover:border-brand-accent hover:text-brand-accent hover:brightness-125 hover:-translate-y-0.5 whitespace-nowrap shrink-0 bg-transparent my-1.5 mx-0.5"
            data-category={cat.id}
            data-i18n={`categories.${cat.id === 'court-metrage' ? 'courtMetrage' : cat.id === 'reseaux-sociaux' ? 'reseauxSociaux' : cat.id}`}
          >
            {cat.label}
          </button>
        ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Empty state -->
  <div class="hidden text-center py-16 reveal-up" id="projects-empty">
    <p class="text-brand-gray-400 text-sm" data-i18n="projects.empty">Aucun projet dans cette catégorie.</p>
  </div>

  <!-- Masonry container -->
   <div class="relative w-full" id="projects-grid">
    {sorted.filter(p => p.category !== 'cache').map((project, i) => {
      const ids = resolveVideoIds(project);
      const hasVideo = !!(project.videoUrl || project.videoFile || ids.youtubeId || ids.vimeoId || (project.preview && /\.(mp4|webm|mov)$/i.test(project.preview)));
      const ratioClass = aspectClass(project.aspectRatio || '16:9');

      const isFirst = i === 0;
      return (
      <article
        class={`project-card group overflow-hidden bg-brand-gray-900 border-0 reveal-up ${ratioClass}`}
        style={`transition-delay: ${(i % 4) * 0.06}s; view-transition-name: project-${project.id}`}
        data-category={project.category || 'youtube'}
        data-youtube={ids.youtubeId}
        data-vimeo={ids.vimeoId}
        data-title={project.title}
        data-video={project.videoUrl || ''}
        data-video-file={project.videoFile || ''}
        data-preview={project.preview || ''}
        data-client={project.client || ''}
        data-description={project.description || ''}
        data-tags={(project.tags || []).join(',')}
        data-aspect={project.aspectRatio || '16:9'}
        data-order={project.order}
        onclick={hasVideo || project.preview ? 'openVideo(this)' : undefined}
      >
        {project.preview && /\.(mp4|webm|mov)$/i.test(project.preview) ? (
          <video loop muted playsinline preload="none"
            poster={posterUrl(project.preview)}
            class="block w-full h-full object-cover lazy-video blur-up"
          >
            <source src={project.preview} type="video/webm" />
          </video>
        ) : project.preview ? (
          <img src={project.preview} alt={project.title}
            class="block w-full h-full object-cover blur-up"
            loading={isFirst ? undefined : 'lazy'}
            fetchpriority={isFirst ? 'high' : undefined}
          />
        ) : (
          <img
            src={thumbnailUrl(project)}
            alt={project.title}
            class="block w-full h-full object-cover blur-up"
            loading={isFirst ? undefined : 'lazy'}
            fetchpriority={isFirst ? 'high' : undefined}
            srcset={ids.youtubeId ? thumbnailSrcset(ids.youtubeId) : undefined}
            sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
          />
        )}
        {hasVideo && (
          <div class="absolute inset-0 bg-brand-black/0 group-hover:bg-brand-black/40 transition-all duration-400 flex items-center justify-center px-3">
            <span class="text-brand-white text-xs uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity duration-400 text-center">{project.title}</span>
          </div>
        )}
      </article>
      );
    })}
    <!-- Portfolio fillers (hidden by default, used to fill last-row gaps) -->
    {Array.from({ length: 5 }).map(() => (
      <article
        class="portfolio-filler hidden group overflow-hidden bg-brand-gray-900 border-0 reveal-up aspect-video"
        data-filler="16:9"
        data-youtube="dQw4w9WgXcQ"
        data-title="🤓🤓🤓"
        data-client="🤓 Rick Astley"
        data-aspect="16:9"
        onclick="openVideo(this)"
      >
        <video src="/projects/portfolio-16x9.webm" loop muted playsinline preload="none" class="block w-full h-full object-cover lazy-video blur-up"></video>
      </article>
    ))}
    {Array.from({ length: 8 }).map(() => (
      <article
        class="portfolio-filler hidden group overflow-hidden bg-brand-gray-900 border-0 reveal-up aspect-[9/16]"
        data-filler="9:16"
        data-youtube="dQw4w9WgXcQ"
        data-title="🤓🤓🤓"
        data-client="🤓 Rick Astley"
        data-aspect="9:16"
        onclick="openVideo(this)"
      >
        <video src="/projects/portfolio-9x16.webm" loop muted playsinline preload="none" class="block w-full h-full object-cover lazy-video blur-up"></video>
      </article>
    ))}
  </div>

  <!-- Hidden card storage for filtered-out cards -->
  <div id="hidden-cards" style="display:none" aria-hidden="true"></div>
</section>

<dialog
  class="fixed inset-0 z-[60] m-0 h-full w-full max-w-none bg-transparent p-0"
  id="video-modal"
  aria-modal="true"
  role="dialog"
>
  <!-- Wave background video -->
  <div class="fixed inset-0 z-0 pointer-events-none">
    <video
      autoplay loop muted playsinline preload="auto"
      class="absolute inset-0 h-full w-full object-cover"
      id="modal-bg-video"
    >
      <source src="/background-wave.webm" type="video/webm" />
    </video>
    <div class="absolute inset-0 bg-brand-black/60"></div>
  </div>
  <!-- Content -->
  <div class="flex h-full flex-col items-center justify-center p-3 md:p-6" style="cursor:auto;">
    <div class="w-full max-w-6xl" style="cursor:auto;" id="modal-content-wrapper">
      <!-- Glass card -->
      <div class="relative tilt-only bg-brand-dark/90 md:bg-brand-dark/70 md:backdrop-blur-2xl border border-white/20 rounded-[40px] shadow-2xl shadow-brand-accent/10 shadow-[inset_0_0_30px_-8px_rgba(255,255,255,0.07)]" data-tilt-max="4">
        <!-- Close button -->
        <div class="flex justify-end pt-3 pr-3 md:pt-4 md:pr-4 pb-3 md:pb-4">
          <button
            onclick="closeModal()"
            aria-label="Fermer"
            class="group flex items-center justify-center w-8 h-8 md:w-10 md:h-10 rounded-full bg-brand-accent/90 hover:bg-brand-accent hover:scale-110 active:scale-95 transition-all duration-300 shadow-lg shadow-brand-accent/30"
          >
            <svg class="w-3.5 h-3.5 md:w-4 md:h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round">
              <path d="M6 6l12 12M18 6l-12 12" />
            </svg>
          </button>
        </div>
        <!-- Player -->
        <div class="relative aspect-video w-full bg-transparent" id="modal-player"></div>
        <!-- Metadata -->
        <div class="px-5 md:px-6 py-4 md:py-5 space-y-2" id="modal-meta">
          <div class="flex items-start justify-between gap-4">
            <h3 class="font-heading text-lg md:text-xl text-brand-white" id="modal-title"></h3>
            <span class="shrink-0 text-[10px] uppercase tracking-widest text-brand-accent bg-brand-accent/10 px-3 py-1 rounded-full" id="modal-category"></span>
          </div>
          <p class="text-brand-gray-400 text-xs md:text-sm leading-relaxed" id="modal-description"></p>
          <div class="flex flex-wrap gap-1.5 pt-1" id="modal-tags"></div>
        </div>
      </div>
    </div>
  </div>
</dialog>

<script>
  const gridEl = document.getElementById('projects-grid')! as HTMLElement;

  // Save filler templates once (preserve across DOM rebuilds)
  const filler169HTML = document.querySelector('.portfolio-filler[data-filler="16:9"]')?.outerHTML;
  const filler916HTML = document.querySelector('.portfolio-filler[data-filler="9:16"]')?.outerHTML;

  // Grid constants
  function rowCols169() {
    const w = window.innerWidth;
    if (w < 640) return 2;
    if (w < 1024) return 3;
    return 5;
  }
  function rowCols916() {
    const w = window.innerWidth;
    if (w < 640) return 3;
    if (w < 1024) return 5;
    return 8;
  }

  function layoutRows() {
    // Collect fillers BEFORE clearing grid (they live inside #projects-grid)
    // Collect all visible non-filler articles
    const articles = [...gridEl.querySelectorAll('article')].filter(c =>
      !c.classList.contains('portfolio-filler') && (c as HTMLElement).style.display !== 'none'
    );

    const cards169 = articles.filter(c =>
      !c.classList.contains('aspect-[9/16]') && !c.classList.contains('aspect-square')
    );
    const cards916 = articles.filter(c =>
      c.classList.contains('aspect-[9/16]') || c.classList.contains('aspect-square')
    );

    const cols169 = rowCols169();
    const cols916 = rowCols916();

    // Clear grid
    while (gridEl.firstChild) gridEl.firstChild.remove();

    let i169 = 0, i916 = 0, rowIndex = 0;

    while (i169 < cards169.length || i916 < cards916.length) {
      const row = document.createElement('div');
      let placed = 0;

      if (rowIndex % 2 === 0) {
        // 16:9 row
        const take = Math.min(cols169, cards169.length - i169);
        row.className = 'grid-row';
        row.style.cssText = `display:grid;grid-template-columns:repeat(${cols169},1fr);gap:0`;
        for (let i = 0; i < take; i++) {
          row.appendChild(cards169[i169 + i]);
          placed++;
        }
        i169 += take;
        // Fill remaining slots with 169 fillers
        if (placed > 0 && placed < cols169 && filler169HTML) {
          for (let f = 0; f < cols169 - placed; f++) {
            const temp = document.createElement('div');
            temp.innerHTML = filler169HTML;
            const filler = temp.firstElementChild as HTMLElement;
            filler.style.display = '';
            filler.classList.remove('hidden', 'reveal-up');
            filler.classList.add('visible');
            row.appendChild(filler);
          }
        }
      } else {
        // 9:16 row
        const take = Math.min(cols916, cards916.length - i916);
        row.className = 'grid-row';
        row.style.cssText = `display:grid;grid-template-columns:repeat(${cols916},1fr);gap:0`;
        for (let i = 0; i < take; i++) {
          row.appendChild(cards916[i916 + i]);
          placed++;
        }
        i916 += take;
        // Fill remaining slots with 916 fillers
        if (placed > 0 && placed < cols916 && filler916HTML) {
          for (let f = 0; f < cols916 - placed; f++) {
            const temp = document.createElement('div');
            temp.innerHTML = filler916HTML;
            const filler = temp.firstElementChild as HTMLElement;
            filler.style.display = '';
            filler.classList.remove('hidden', 'reveal-up');
            filler.classList.add('visible');
            row.appendChild(filler);
          }
        }
      }

      if (row.children.length > 0) gridEl.appendChild(row);
      rowIndex++;
    }

    // Re-observe lazy videos after DOM rebuild
    document.querySelectorAll('.lazy-video').forEach(v => {
      if (!videoObserver) return;
      videoObserver.observe(v);
    });
    // Re-observe video blurs (handled by play() promise in processPlayQueue)
    document.querySelectorAll('img.blur-up').forEach(resolveBlurUp);
  }

  // Debounced resize
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      layoutRows();
      updateScrollFade();
    }, 200);
  });

  // ── Lazy-load preview videos — staggered, visual order ──
  // Only trigger play() when videos are truly in viewport (rootMargin: 0)
  // Queue is sorted by DOM document position (left→right, top→bottom)
  // Controls cadence to avoid main-thread jank from parallel media init
  const videoPlayQueue: HTMLVideoElement[] = [];
  let videoPlaying = false;

  function processPlayQueue() {
    if (videoPlaying || videoPlayQueue.length === 0) return;
    videoPlaying = true;

    // Sort queue by visual DOM order (left→right, top→bottom)
    videoPlayQueue.sort((a, b) => {
      const aArt = a.closest('article');
      const bArt = b.closest('article');
      if (!aArt || !bArt) return 0;
      const pos = aArt.compareDocumentPosition(bArt);
      if (pos & Node.DOCUMENT_POSITION_FOLLOWING) return -1;
      if (pos & Node.DOCUMENT_POSITION_PRECEDING) return 1;
      return 0;
    });

    const video = videoPlayQueue.shift()!;

    // Start loading + playback (browser handles media init)
    video.play()
      .then(() => {
        // Remove blur when content actually renders
        if (video.classList.contains('blur-up')) video.classList.add('loaded');
      })
      .catch(() => {
        // Even if play fails (network error, autoplay policy), remove blur
        if (video.classList.contains('blur-up')) video.classList.add('loaded');
      });

    // Process next after stagger delay — prevents burst of media pipeline inits
    setTimeout(() => {
      videoPlaying = false;
      processPlayQueue();
    }, 400);
  }

  const lazyMargin = '0px';
  const videoObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const video = entry.target as HTMLVideoElement;
      if (entry.isIntersecting) {
        if (!videoPlayQueue.includes(video) && video.paused) {
          videoPlayQueue.push(video);
          processPlayQueue();
        }
      } else {
        video.pause();
        // Remove from queue
        const idx = videoPlayQueue.indexOf(video);
        if (idx !== -1) videoPlayQueue.splice(idx, 1);
      }
    });
  }, { rootMargin: lazyMargin });

  document.querySelectorAll('.lazy-video').forEach(v => videoObserver.observe(v));

  // Blur-up: images — remove blur on load OR error (broken image)
  function resolveBlurUp(el: Element) {
    const img = el as HTMLImageElement;
    if (img.complete) {
      img.classList.add('loaded');
    } else {
      img.addEventListener('load', () => img.classList.add('loaded'), { once: true });
      img.addEventListener('error', () => img.classList.add('loaded'), { once: true });
    }
  }
  document.querySelectorAll('img.blur-up').forEach(resolveBlurUp);

  // Category filtering
  function updateScrollFade() {
    const container = document.getElementById('category-filters')!;
    const leftFade = document.querySelector('.filters-fade-left') as HTMLElement;
    const rightFade = document.querySelector('.filters-fade-right') as HTMLElement;
    if (!leftFade || !rightFade) return;
    const canScroll = container.scrollWidth > container.clientWidth;
    if (!canScroll) {
      leftFade.style.opacity = '0';
      rightFade.style.opacity = '0';
      return;
    }
    leftFade.style.opacity = container.scrollLeft > 4 ? '1' : '0';
    rightFade.style.opacity = container.scrollLeft < container.scrollWidth - container.clientWidth - 4 ? '1' : '0';
  }

  document.getElementById('category-filters')!.addEventListener('scroll', updateScrollFade, { passive: true });
  setTimeout(updateScrollFade, 200);

  function updateFilters(cat: string) {
    const hiddenEl = document.getElementById('hidden-cards')!;

    document.querySelectorAll('.cat-btn').forEach(b => {
      const isActive = b.getAttribute('data-category') === cat;
      b.classList.toggle('border-brand-accent', isActive);
      b.classList.toggle('text-brand-accent', isActive);
      b.classList.toggle('bg-brand-accent/15', isActive);
      b.classList.toggle('border-brand-white/10', !isActive);
      b.classList.toggle('text-brand-gray-400', !isActive);
      b.classList.toggle('bg-transparent', !isActive);
    });

    let visibleCount = 0;
    const cards = document.querySelectorAll('#projects-grid article, #projects-grid .grid-row > article, #hidden-cards article');

    cards.forEach((card) => {
      if (card.classList.contains('portfolio-filler')) return;
      const cardCat = card.getAttribute('data-category') || '';
      const visible = cat === 'all' || cardCat === cat;
      const el = card as HTMLElement;

      if (visible) {
        visibleCount++;
        el.style.display = '';
        el.classList.remove('filtered-out');
        // Move back to grid (layoutRows re-orders by aspect ratio)
        if (el.parentElement?.id === 'hidden-cards') {
          gridEl.appendChild(el);
        }
      } else {
        el.classList.add('filtered-out');
        el.style.display = 'none';
        // Move to hidden container from grid
        if (el.parentElement?.id !== 'hidden-cards') {
          hiddenEl.appendChild(el);
        }
      }
    });

    layoutRows();

    const emptyEl = document.getElementById('projects-empty')!;
    if (visibleCount === 0) {
      gridEl.style.display = 'none';
      emptyEl.classList.remove('hidden');
      emptyEl.classList.add('visible');
    } else {
      gridEl.style.display = '';
      emptyEl.classList.add('hidden');
      emptyEl.classList.remove('visible');
    }
  }

  // Init
  updateFilters('all');
  setTimeout(() => layoutRows(), 50);
  setTimeout(() => layoutRows(), 150);
  window.addEventListener('load', () => { layoutRows(); updateScrollFade(); });

  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      updateFilters(btn.getAttribute('data-category')!);
    });
  });

  // Video modal
  const modal = document.getElementById('video-modal') as HTMLDialogElement | null;
  let modalAnimating = false;

  function extractYtId(url: string): string | null {
    const m = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/shorts\/)([a-zA-Z0-9_-]{11})/);
    return m ? m[1] : null;
  }

  function catLabel(id: string): string {
    const map: Record<string, string> = {
      youtube: 'YouTube',
      'court-metrage': document.documentElement.lang === 'fr' ? 'Court-Métrage' : 'Short Film',
      'reseaux-sociaux': document.documentElement.lang === 'fr' ? 'Réseaux Sociaux' : 'Social Media',
    };
    return map[id] || id;
  }

  (window as any).openVideo = function(el: HTMLElement) {
    const videoFile = el.dataset.videoFile || '';
    const videoUrl = el.dataset.video || '';
    const youtubeId = el.dataset.youtube || '';
    const preview = el.dataset.preview || '';
    const title = el.dataset.title || '';
    const client = el.dataset.client || '';
    const description = el.dataset.description || '';
    const tags = (el.dataset.tags || '').split(',').filter(Boolean);
    const category = el.dataset.category || '';
    const aspect = el.dataset.aspect || '16:9';

    // Adjust modal layout for 9:16 videos
    const contentWrapper = document.getElementById('modal-content-wrapper');
    const playerDiv = document.getElementById('modal-player');
    if (contentWrapper) {
      contentWrapper.className = aspect === '9:16'
        ? 'w-full max-w-[420px] mx-auto'
        : 'w-full max-w-6xl';
    }
    if (playerDiv) {
      playerDiv.className = aspect === '9:16'
        ? 'relative aspect-[9/16] w-full bg-transparent'
        : 'relative aspect-video w-full bg-transparent';
    }

    // Instagram → new tab (can't embed)
    if (videoUrl && videoUrl.includes('instagram.com')) {
      window.open(videoUrl, '_blank', 'noopener,noreferrer');
      return;
    }

    if (!modal || modalAnimating) return;

    // Populate metadata
    const titleEl = document.getElementById('modal-title');
    const catEl = document.getElementById('modal-category');
    const descEl = document.getElementById('modal-description');
    const tagsEl = document.getElementById('modal-tags');

    if (titleEl) titleEl.textContent = title;
    if (catEl) catEl.textContent = client || catLabel(category);
    if (descEl) descEl.textContent = description;
    if (tagsEl) {
      tagsEl.innerHTML = '';
      tags.forEach(t => {
        const lang = document.documentElement.lang || 'fr';
        const dict = (window as any).__tagsDict || {};
        const translated = dict[t] ? dict[t][lang as 'fr' | 'en'] : t;
        const span = document.createElement('span');
        span.className = 'px-2.5 py-0.5 text-[9px] uppercase tracking-wider border rounded-full border-brand-white/10 text-brand-gray-400 bg-brand-white/5';
        span.textContent = translated;
        tagsEl.appendChild(span);
      });
    }

    const ytId = youtubeId || extractYtId(videoUrl);
    const container = modal.querySelector('#modal-player')!;

    const isFiller = el.dataset.filler !== undefined;
    if (ytId) {
      const thumbUrl = `/yt-thumb/${ytId}?size=maxresdefault`;
      // Fillers auto-play immediately; other projects show a click-to-play facade
      if (isFiller) {
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${ytId}?autoplay=1&rel=0`;
        iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.className = 'absolute inset-0 w-full h-full border-0';
        container.appendChild(iframe);
      } else {
        const facade = document.createElement('div');
        facade.className = 'absolute inset-0 cursor-pointer group/facade';
        facade.innerHTML = `
          <img src="${thumbUrl}" alt="" class="absolute inset-0 w-full h-full object-cover"
            onerror="this.src='/yt-thumb/${ytId}?size=hqdefault'" />
          <div class="absolute inset-0 bg-black/30 group-hover/facade:bg-black/50 transition-colors duration-300 flex items-center justify-center">
            <div class="w-14 h-14 md:w-20 md:h-20 rounded-full bg-brand-accent flex items-center justify-center group-hover/facade:scale-110 transition-transform duration-300 shadow-lg shadow-brand-accent/40">
              <svg class="w-6 h-6 md:w-8 md:h-8 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>`;
        facade.addEventListener('click', () => {
          const iframe = document.createElement('iframe');
          iframe.src = `https://www.youtube-nocookie.com/embed/${ytId}?autoplay=1&rel=0`;
          iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
          iframe.allowFullscreen = true;
          iframe.className = 'absolute inset-0 w-full h-full border-0';
          facade.replaceWith(iframe);
        });
        container.appendChild(facade);
      }
    } else if (videoFile) {
      // Local video file
      const video = document.createElement('video');
      video.controls = true;
      video.autoplay = true;
      video.className = 'absolute inset-0 h-full w-full border-0 object-contain';
      const vSrc = document.createElement('source');
      vSrc.src = videoFile.replace(/\.(mp4|mov)$/i, '.webm');
      vSrc.type = 'video/webm';
      video.appendChild(vSrc);
      container.appendChild(video);
    } else if (preview) {
      // Preview file (video or image)
      const isVideo = /\.(mp4|webm|mov)$/i.test(preview);
      if (isVideo) {
        const video = document.createElement('video');
        video.controls = true;
        video.autoplay = true;
        video.className = 'absolute inset-0 h-full w-full border-0 object-contain';
        const vSrc = document.createElement('source');
        vSrc.src = preview.replace(/\.(mp4|mov)$/i, '.webm');
        vSrc.type = 'video/webm';
        video.appendChild(vSrc);
        container.appendChild(video);
      } else {
        const img = document.createElement('img');
        img.src = preview;
        img.alt = title;
        img.className = 'absolute inset-0 h-full w-full border-0 object-contain';
        container.appendChild(img);
      }
    } else {
      // Fallback: open in new tab
      window.open(videoUrl, '_blank', 'noopener,noreferrer');
      return;
    }

    const wrapper = modal.firstElementChild as HTMLElement;
    wrapper.style.opacity = '0';
    wrapper.style.transform = 'scale(0.92)';
    wrapper.style.transition = 'opacity 0.35s ease-out, transform 0.35s ease-out';

    modal.showModal();
    // Start modal background video
    const bgVideo = document.getElementById('modal-bg-video') as HTMLVideoElement | null;
    if (bgVideo) { bgVideo.currentTime = 0; bgVideo.play().catch(() => {}); }
    document.body.style.overflow = 'hidden';
    // Focus the close button
    const closeBtn = modal.querySelector('button') as HTMLButtonElement | null;
    if (closeBtn) setTimeout(() => closeBtn.focus(), 100);

    requestAnimationFrame(() => {
      wrapper.style.opacity = '1';
      wrapper.style.transform = 'scale(1)';
    });

    const dot = document.getElementById('cursor-dot');
    if (dot) dot.style.display = 'none';
  };

  (window as any).closeModal = function() {
    if (!modal || modalAnimating) return;
    modalAnimating = true;

    modal.close();
    document.body.style.overflow = '';
    const dot = document.getElementById('cursor-dot');
    if (dot) dot.style.display = '';
    modalAnimating = false;
  };

  if (modal) {
    // Focus trap
    function getFocusableElements(): HTMLElement[] {
      const els = modal!.querySelectorAll<HTMLElement>(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      return Array.from(els).filter(el => !!(el as HTMLElement).offsetParent);
    }

    function trapFocus(e: KeyboardEvent) {
      if (e.key !== 'Tab' || !modal!.open) return;
      const focusable = getFocusableElements();
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }

    document.addEventListener('keydown', trapFocus);

    // Swipe to close
    let touchStartY = 0;
    modal.addEventListener('touchstart', (e) => {
      touchStartY = (e as TouchEvent).touches[0].clientY;
    }, { passive: true });

    modal.addEventListener('touchend', (e) => {
      const deltaY = (e as TouchEvent).changedTouches[0].clientY - touchStartY;
      const target = e.target as HTMLElement;
      if (deltaY > 60 && !target.closest('button, a, input')) {
        (window as any).closeModal();
      }
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) (window as any).closeModal();
    });
    modal.addEventListener('close', () => {
      const container = modal.querySelector('#modal-player');
      if (container) container.innerHTML = '';
      // Reset modal layout to default (16:9)
      const contentWrapper = document.getElementById('modal-content-wrapper');
      const playerDiv = document.getElementById('modal-player');
      if (contentWrapper) contentWrapper.className = 'w-full max-w-6xl';
      if (playerDiv) playerDiv.className = 'relative aspect-video w-full bg-transparent';
      const titleEl = document.getElementById('modal-title');
      const descEl = document.getElementById('modal-description');
      const tagsEl = document.getElementById('modal-tags');
      if (titleEl) titleEl.textContent = '';
      if (descEl) descEl.textContent = '';
      if (tagsEl) tagsEl.innerHTML = '';
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.open) (window as any).closeModal();
    });
  }
</script>

<style>
  #projects-grid {
    display: flex;
    flex-direction: column;
  }
  #projects-grid > article {
    position: relative;
    width: 100%;
  }
</style>
