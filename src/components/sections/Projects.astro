---
import { getCollection } from 'astro:content';
import { categories } from '../../consts';

const projects = await getCollection('projects');
const sorted = projects
  .map((p) => ({ ...p.data, id: p.id }))
  .sort((a, b) => a.order - b.order);

function thumbnailUrl(project: typeof sorted[number]) {
  if (project.youtubeId) {
    return `https://img.youtube.com/vi/${project.youtubeId}/hqdefault.jpg`;
  }
  if (project.vimeoId) {
    return project.thumbnail || '/placeholder-thumb.jpg';
  }
  return project.thumbnail || '/placeholder-thumb.jpg';
}

function extractYoutubeId(url: string): string | null {
  const patterns = [
    /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/shorts\/)([a-zA-Z0-9_-]{11})/,
  ];
  for (const p of patterns) {
    const m = url.match(p);
    if (m) return m[1];
  }
  return null;
}

function extractVimeoId(url: string): string | null {
  const m = url.match(/vimeo\.com\/(\d+)/);
  return m ? m[1] : null;
}

function resolveVideoIds(project: typeof sorted[number]) {
  let youtubeId = project.youtubeId || '';
  let vimeoId = project.vimeoId || '';
  if (!youtubeId && !vimeoId && project.videoUrl) {
    youtubeId = extractYoutubeId(project.videoUrl) || '';
    if (!youtubeId) vimeoId = extractVimeoId(project.videoUrl) || '';
  }
  return { youtubeId, vimeoId };
}

function aspectClass(ratio: string) {
  switch (ratio) {
    case '9:16': return 'aspect-[9/16]';
    case '1:1': return 'aspect-square';
    default: return 'aspect-video';
  }
}
---

<section id="projects" class="relative z-10 w-full">
  <!-- Category filters -->
  <div class="px-6 pb-6 flex flex-wrap gap-2 reveal-up" id="category-filters">
    {categories.map((cat) => (
      <button
        class="cat-btn px-4 py-1.5 text-[11px] uppercase tracking-widest border rounded-full transition-colors border-brand-gray-800 text-brand-gray-400 hover:border-brand-gray-400"
        data-category={cat.id}
        data-i18n={`categories.${cat.id === 'court-metrage' ? 'courtMetrage' : cat.id === 'reseaux-sociaux' ? 'reseauxSociaux' : cat.id}`}
      >
        {cat.label}
      </button>
    ))}
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-0" id="projects-grid">
    {sorted.map((project, i) => {
      const ids = resolveVideoIds(project);
      const hasVideo = !!(project.videoUrl || project.videoFile || ids.youtubeId || ids.vimeoId);
      const ratioClass = aspectClass(project.aspectRatio || '16:9');
      return (
      <article
        class={`project-card group relative overflow-hidden bg-brand-gray-900 border-0 reveal-up ${ratioClass}`}
        style={`transition-delay: ${(i % 4) * 0.06}s; view-transition-name: project-${project.id}`}
        data-category={project.category || 'youtube'}
        data-youtube={ids.youtubeId}
        data-vimeo={ids.vimeoId}
        data-title={project.title}
        data-video={project.videoUrl || ''}
        data-video-file={project.videoFile || ''}
        onclick={hasVideo ? 'openVideo(this)' : undefined}
      >
        {project.preview && /\.(mp4|webm|mov)$/i.test(project.preview) ? (
          <video src={project.preview} autoplay loop muted playsinline
            class="w-full h-full object-cover"
          />
        ) : project.preview ? (
          <img src={project.preview} alt={project.title}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        ) : (
          <img
            src={thumbnailUrl(project)}
            alt={project.title}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        )}
        {hasVideo && (
          <div class="absolute inset-0 bg-brand-black/0 group-hover:bg-brand-black/40 transition-all duration-400 flex items-center justify-center">
            <span class="text-brand-white text-xs uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity duration-400">{project.title}</span>
          </div>
        )}
      </article>
      );
    })}
  </div>
</section>

<dialog
  class="fixed inset-0 z-[60] m-0 h-full w-full max-w-none bg-brand-black p-0"
  id="video-modal"
  aria-modal="true"
  role="dialog"
  style="--tw-bg-opacity:1; background-color:rgb(0,0,0);"
>
  <div class="flex h-full flex-col items-center justify-center p-6" style="cursor:auto;">
    <div class="w-full max-w-5xl" style="cursor:auto;">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-heading text-lg text-brand-white"></h2>
        <button
          class="text-brand-gray-400 hover:text-brand-white transition-colors text-sm uppercase tracking-wider"
          onclick="closeModal()"
          data-i18n="modal.close"
        >
          Fermer
        </button>
      </div>
      <div class="relative aspect-video w-full bg-brand-black"></div>
    </div>
  </div>
</dialog>

<script>
  // Category filtering
  let activeCat = 'all';

  function updateFilters(cat: string) {
    activeCat = cat;
    document.querySelectorAll('.cat-btn').forEach(b => {
      const isActive = b.getAttribute('data-category') === cat;
      b.classList.toggle('border-brand-white', isActive);
      b.classList.toggle('text-brand-white', isActive);
      b.classList.toggle('bg-brand-white/10', isActive);
      b.classList.toggle('border-brand-gray-800', !isActive);
      b.classList.toggle('text-brand-gray-400', !isActive);
    });
    let visibleCount = 0;
    const cards = document.querySelectorAll('#projects-grid > article');
    cards.forEach((card) => {
      const cardCat = card.getAttribute('data-category') || '';
      const visible = cat === 'all' || cardCat === cat;
      const el = card as HTMLElement;
      if (visible) {
        visibleCount++;
        el.style.display = '';
        el.classList.add('filtered-out');
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            el.classList.remove('filtered-out');
          });
        });
      } else {
        el.classList.add('filtered-out');
        setTimeout(() => {
          if (el.classList.contains('filtered-out')) {
            el.style.display = 'none';
          }
        }, 350);
      }
    });
  }

  // Init: "All" active by default
  updateFilters('all');

  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      updateFilters(btn.getAttribute('data-category')!);
    });
  });

  // Video modal
  const modal = document.getElementById('video-modal') as HTMLDialogElement | null;
  let modalAnimating = false;

  (window as any).openVideo = function(el: HTMLElement) {
    if (!modal || modalAnimating) return;

    const videoFile = el.dataset.videoFile || '';
    let youtubeId = el.dataset.youtube || '';
    let vimeoId = el.dataset.vimeo || '';
    const videoUrl = el.dataset.video || '';
    const title = el.dataset.title || '';

    const container = modal.querySelector('.aspect-video')!;

    if (videoFile) {
      const video = document.createElement('video');
      video.src = videoFile;
      video.controls = true;
      video.autoplay = true;
      video.className = 'absolute inset-0 h-full w-full border-0 object-contain';
      container.appendChild(video);
    } else {
      if (!youtubeId && !vimeoId && videoUrl) {
        const ytMatch = videoUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/shorts\/)([a-zA-Z0-9_-]{11})/);
        if (ytMatch) { youtubeId = ytMatch[1]; }
        else {
          const vmMatch = videoUrl.match(/vimeo\.com\/(\d+)/);
          if (vmMatch) { vimeoId = vmMatch[1]; }
        }
      }

      const iframe = document.createElement('iframe');
      iframe.allow = 'autoplay; fullscreen';
      iframe.allowFullscreen = true;
      iframe.className = 'absolute inset-0 h-full w-full border-0';

      if (youtubeId) {
        iframe.src = `https://www.youtube-nocookie.com/embed/${youtubeId}?autoplay=1&rel=0`;
      } else if (vimeoId) {
        iframe.src = `https://player.vimeo.com/video/${vimeoId}?autoplay=1&dnt=1`;
      }

      iframe.title = title;
      container.appendChild(iframe);
    }

    modal.querySelector('h2')!.textContent = title;

    const wrapper = modal.firstElementChild as HTMLElement;
    wrapper.style.opacity = '0';
    wrapper.style.transform = 'scale(0.92)';
    wrapper.style.transition = 'opacity 0.35s ease-out, transform 0.35s ease-out';

    modal.showModal();
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(() => {
      wrapper.style.opacity = '1';
      wrapper.style.transform = 'scale(1)';
    });

    const dot = document.getElementById('cursor-dot');
    if (dot) dot.style.display = 'none';
  };

  (window as any).closeModal = function() {
    if (!modal || modalAnimating) return;
    modalAnimating = true;

    const wrapper = modal.firstElementChild as HTMLElement;
    wrapper.style.opacity = '0';
    wrapper.style.transform = 'scale(0.92)';

    setTimeout(() => {
      modal.close();
      modalAnimating = false;
    }, 300);
  };

  if (modal) {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) (window as any).closeModal();
    });
    modal.addEventListener('close', () => {
      modal.querySelector('iframe')?.remove();
      modal.querySelector('video')?.remove();
      document.body.style.overflow = '';
      const dot = document.getElementById('cursor-dot');
      if (dot) dot.style.display = '';
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.open) (window as any).closeModal();
    });
  }
</script>
