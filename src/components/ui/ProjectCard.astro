---
export interface Props {
  title: string;
  description: string;
  thumbnail: string;
  tags: string[];
  youtubeId?: string;
  vimeoId?: string;
  videoUrl: string;
  featured?: boolean;
}

const { title, youtubeId, vimeoId, videoUrl } = Astro.props;
---

<article
  class="group relative aspect-video overflow-hidden bg-brand-gray-950 cursor-pointer"
  onclick={`openVideoModal('${title}', '${videoUrl}', '${youtubeId ?? ''}', '${vimeoId ?? ''}')`}
>
  <div class="w-full h-full bg-brand-gray-900 flex items-center justify-center">
    <span class="text-brand-gray-600 text-xs tracking-wider">{title}</span>
  </div>

  <div class="absolute inset-0 bg-brand-black/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
    <span class="text-brand-white text-xs uppercase tracking-widest">{title}</span>
  </div>
</article>
