---
import { site } from '../../consts';

type Platform = keyof typeof site.socials;

const labels: Record<Platform, string> = {
  instagram: 'Instagram',
  linkedin: 'LinkedIn',
};

const entries = Object.entries(site.socials) as [Platform, string][];
---

<div class="flex items-center gap-6">
  {
    entries.map(([platform, url]) => (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-brand-gray-400 hover:text-brand-white transition-colors text-sm uppercase tracking-wider"
        aria-label={labels[platform]}
      >
        {platform}
      </a>
    ))
  }
</div>
