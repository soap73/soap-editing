---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pageUrl?: string;
  schema?: object;
}

const {
  title = 'Soap Edit | Montage Vidéo, Motion Design & Sound Design',
  description = "Anthony Vuillerot — Monteur vidéo à Lyon. Soap Edit : montage vidéo professionnel, motion design et sound design pour YouTube, réseaux sociaux et courts-métrages.",
  ogImage = '/og-image.webp',
  pageUrl = '',
  schema,
} = Astro.props;
const siteUrl = 'https://soap-edit.com';
const canonicalUrl = pageUrl ? `${siteUrl}${pageUrl}` : siteUrl;
---

<!doctype html>
<html lang="fr" class="bg-brand-black text-brand-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalUrl} />
    <meta name="google-site-verification" content="CWXbB_m4I58IAugewJFuTkfjDS4WPEmR0VtBOmDAA-I" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Anthony Vuillerot" />

    <link rel="alternate" hreflang="fr" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Soap Edit" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dm-serif-display-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dm-serif-display-latin-400-italic.woff2" as="font" type="font/woff2" crossorigin />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

  </head>
  <body class="min-h-screen antialiased">
    <noscript>
      <div class="fixed top-0 left-0 right-0 z-50 bg-brand-accent text-brand-black text-center text-xs py-1 px-4 font-medium">
        Certaines fonctionnalités (animations, changement de langue) nécessitent JavaScript.
      </div>
    </noscript>
    <!-- Preloader -->
    <div class="preloader" id="preloader" aria-hidden="true">
      <div class="preloader-content">
        <span class="preloader-line preloader-line-top"></span>
        <span class="preloader-text">Soap<span class="preloader-accent">Edit</span></span>
        <span class="preloader-line preloader-line-bottom"></span>
      </div>
    </div>

    <div class="cursor-dot" id="cursor-dot"></div>
    <div class="scroll-progress" id="scroll-progress"></div>

    <!-- Lang switcher -->
    <div
      id="lang-switcher"
      class="fixed top-3 right-3 md:top-5 md:right-5 z-50 flex text-[10px] md:text-sm uppercase tracking-widest bg-brand-dark/60 backdrop-blur-2xl border border-white/20 rounded-full overflow-hidden shadow-xl"
      aria-label="Switch language"
    >
      <button class="lang-option px-3 py-1.5 md:px-5 md:py-2.5 transition-all duration-300 text-brand-gray-400 hover:text-brand-white" data-lang="fr">FR</button>
      <button class="lang-option px-3 py-1.5 md:px-5 md:py-2.5 transition-all duration-300 text-brand-gray-400 hover:text-brand-white" data-lang="en">EN</button>
    </div>

    <slot />

  </body>
</html>

<script>
  // ── Device detection ───────────────────────────────────
  const isTouchDevice = 'ontouchstart' in window || matchMedia('(pointer: coarse)').matches;
  const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent) && !isTouchDevice;

  // ── i18n ──────────────────────────────────────────────
  const tagsDict: Record<string, {fr: string, en: string}> = {
    'Drame': { fr: 'Drame', en: 'Drama' },
    'Humour': { fr: 'Humour', en: 'Comedy' },
    'Motion Design': { fr: 'Motion Design', en: 'Motion Design' },
    'Map': { fr: 'Map', en: 'Map' },
    'YouTube': { fr: 'YouTube', en: 'YouTube' },
    'Sound Design': { fr: 'Sound Design', en: 'Sound Design' },
    'court-métrage': { fr: 'Court-métrage', en: 'Short Film' },
    'Zombies': { fr: 'Zombies', en: 'Zombies' },
    "L'Amour": { fr: "L'Amour", en: 'Love' },
    'Les Rêves': { fr: 'Les Rêves', en: 'Dreams' },
    'La Beauté': { fr: 'La Beauté', en: 'Beauty' },
    'Un Super Pouvoir': { fr: 'Un Super Pouvoir', en: 'A Superpower' },
    'Amour': { fr: 'Amour', en: 'Love' },
  };
  (window as any).__tagsDict = tagsDict;

  const t = {
    fr: {
      taglineBubbles: 'Monteur Vidéo,Motion Designer,Sound Designer',
      categories: { all: 'Tout', youtube: 'YouTube', courtMetrage: 'Courts-Métrages', reseauxSociaux: 'Réseaux Sociaux' },
      projects: { empty: 'Aucun projet dans cette catégorie.' },
      heroIntro: "L'art de raconter des histoires par le montage. Montage vidéo de haute qualité.",

      about: {
        title: 'À propos',
        intro1: "L'art de raconter des histoires par le montage.",
        intro2: "Monteur vidéo basé à Lyon, je combine storytelling, motion design et sound design pour transformer vos idées en vidéos percutantes, au rendu professionnel et mémorable.",
        projectsCount: 'Projets livrés',
        yearsExp: "Années d'expérience",
        stack: 'Stack',
        clients: 'Clients',
      },
      contact: {
        title: 'Contact',
        subtitle: 'Un projet, une collaboration ? Discutons-en !',
        responseTime: "Réponse sous 24h",
        responseTimeSuffix: "(sauf si je monte)",
        email: 'Email',
        instagram: 'Instagram',
        linkedin: 'LinkedIn',
        services: {
          editing: 'Montage',
          motion: 'Motion-design',
          sound: 'Sound-design',
          color: 'Colorimétrie',
          compositing: 'Compositing',
          vfx: 'VFX',
        },
      },
      '404': { message: "Cette page n'existe pas.", back: "Retour à l'accueil" },
      legal: {
        back: '← Retour',
        title: 'Mentions Légales',
        editor: { title: 'Éditeur du site', status: 'Statut : Entreprise individuelle' },
        hosting: { title: 'Hébergement', website: 'Site web : cloudflare.com' },
        ip: {
          title: 'Propriété intellectuelle',
          text: "L'ensemble du contenu de ce site (textes, vidéos, images, logo) est la propriété exclusive de Soap Edit, sauf mention contraire. Toute reproduction, distribution, modification ou utilisation sans autorisation préalable est interdite et constitue une violation du Code de la propriété intellectuelle.",
        },
        privacy: {
          title: 'Données personnelles',
          text: "Ce site ne collecte aucune donnée personnelle sans votre consentement. Il n'utilise pas de cookies de tracking. Conformément au Règlement Général sur la Protection des Données (RGPD) et à la loi Informatique et Libertés, vous disposez d'un droit d'accès, de rectification et de suppression des données vous concernant. Pour exercer ce droit, contactez-nous à l'adresse email ci-dessus.",
        },
        cookies: {
          title: 'Cookies',
          text: 'Ce site n\'utilise pas de cookies tiers à des fins de tracking ou de publicité. Seuls des cookies techniques strictement nécessaires au fonctionnement du site peuvent être déposés.',
        },
        credits: { title: 'Crédits', design: 'Design & développement : Soap Edit' },
      },
      footer: { legalLink: 'Mentions légales', rights: 'Tous droits réservés.' },
      available: 'Disponible',
    },
    en: {
      taglineBubbles: 'Video Editor,Motion Designer,Sound Designer',
      categories: { all: 'All', youtube: 'YouTube', courtMetrage: 'Short Films', reseauxSociaux: 'Social Media' },
      projects: { empty: 'No projects in this category.' },
      heroIntro: 'The art of storytelling through editing. High-quality video editing.',

      modal: { close: 'Close' },
      about: {
        title: 'About',
        intro1: 'The art of storytelling through editing.',
        intro2: 'Video editor based in Lyon, France. I combine storytelling, motion design and sound design to transform your ideas into impactful, professional and memorable videos.',
        projectsCount: 'Projects delivered',
        yearsExp: 'Years of experience',
        stack: 'Stack',
        clients: 'Clients',
      },
      contact: {
        title: 'Contact',
        subtitle: 'A project, a collaboration? Let\'s talk!',
        responseTime: 'Response within 24h',
        responseTimeSuffix: '(unless I\'m editing)',
        email: 'Email',
        instagram: 'Instagram',
        linkedin: 'LinkedIn',
        services: {
          editing: 'Editing',
          motion: 'Motion-design',
          sound: 'Sound-design',
          color: 'Color Grading',
          compositing: 'Compositing',
          vfx: 'VFX',
        },
      },
      '404': { message: "This page doesn't exist.", back: 'Back to home' },
      legal: {
        back: '← Back',
        title: 'Legal Notice',
        editor: { title: 'Site Publisher', status: 'Status: Sole proprietorship' },
        hosting: { title: 'Hosting', website: 'Website: cloudflare.com' },
        ip: {
          title: 'Intellectual Property',
          text: 'All content on this site (text, videos, images, logo) is the exclusive property of Soap Edit, unless otherwise stated. Any reproduction, distribution, modification or use without prior authorization is prohibited and constitutes a violation of the French Intellectual Property Code.',
        },
        privacy: {
          title: 'Personal Data',
          text: "This site does not collect any personal data without your consent. It does not use tracking cookies. In accordance with the General Data Protection Regulation (GDPR) and the French Data Protection Act, you have the right to access, rectify and delete your personal data. To exercise this right, contact us at the email address above.",
        },
        cookies: {
          title: 'Cookies',
          text: 'This site does not use third-party cookies for tracking or advertising purposes. Only strictly necessary technical cookies may be placed for the proper functioning of the site.',
        },
        credits: { title: 'Credits', design: 'Design & development: Soap Edit' },
      },
      footer: { legalLink: 'Legal Notice', rights: 'All rights reserved.' },
      available: 'Available',
    },
  };

  function setLang(lang: string) {
    document.documentElement.lang = lang;
    localStorage.setItem('lang', lang);
    // Update toggle buttons
    document.querySelectorAll('.lang-option').forEach((btn: any) => {
      const isActive = btn.dataset.lang === lang;
      if (isActive) {
        btn.classList.add('bg-brand-accent', 'text-brand-white', 'rounded-full');
        btn.classList.remove('text-brand-gray-400');
      } else {
        btn.classList.remove('bg-brand-accent', 'text-brand-white', 'rounded-full');
        btn.classList.add('text-brand-gray-400');
      }
    });

    const d = t[lang as 'fr' | 'en'];

    document.querySelectorAll('[data-i18n]').forEach((el: any) => {
      const key = el.dataset.i18n;
      const keys = key.split('.');
      let val: any = d;
      for (const k of keys) val = val?.[k];
      if (val) el.textContent = val;
    });

    // Tagline bubble carousel
    const bubble = document.getElementById('tagline-bubble');
    if (bubble) {
      const raw = bubble.textContent || '';
      const words = raw.split(',').map((w: string) => w.trim()).filter(Boolean);
      if (words.length > 1) {
        let idx = 0;
        bubble.textContent = words[0];
        (window as any).__taglineInterval && clearInterval((window as any).__taglineInterval);
        (window as any).__taglineInterval = setInterval(() => {
          idx = (idx + 1) % words.length;
          bubble.style.opacity = '0';
          bubble.style.transform = 'scale(0.95)';
          setTimeout(() => {
            bubble.textContent = words[idx];
            bubble.style.opacity = '1';
            bubble.style.transform = 'scale(1)';
          }, 200);
        }, 2500);
      }
    }

    // Update placeholders
    document.querySelectorAll('[data-i18n-placeholder]').forEach((el: any) => {
      const key = el.dataset.i18nPlaceholder;
      const keys = key.split('.');
      let val: any = d;
      for (const k of keys) val = val?.[k];
      if (val) el.placeholder = val;
    });
  }

  const saved = localStorage.getItem('lang') || 'fr';
  setLang(saved);

  // Click handlers on each lang option
  document.querySelectorAll('.lang-option').forEach((btn: any) => {
    btn.addEventListener('click', () => {
      setLang(btn.dataset.lang);
    });
  });

  // ── Preloader ─────────────────────────────────────────
  const preloader = document.getElementById('preloader')!;
  window.addEventListener('load', () => {
    setTimeout(() => {
      preloader.classList.add('done');
    }, 800);
  });

  // Scroll reveal — observe all .reveal-up elements
  const isMobile = window.innerWidth < 640;
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: isMobile ? '0px 0px -10px 0px' : '0px 0px -40px 0px' });

  function observeReveal() {
    document.querySelectorAll('.reveal-up:not(.visible)').forEach(el => revealObserver.observe(el));
  }
  observeReveal();

  // Re-observe after page transitions (if ClientRouter used)
  document.addEventListener('astro:page-load', () => {
    observeReveal();
    setLang(document.documentElement.lang || 'fr');
  });

  // Scroll progress (throttled via requestAnimationFrame)
  const progress = document.getElementById('scroll-progress')!;
  let scrollTicking = false;
  window.addEventListener('scroll', () => {
    if (!scrollTicking) {
      requestAnimationFrame(() => {
        const scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        progress.style.width = Math.min(scrollPercent, 100) + '%';
        scrollTicking = false;
      });
      scrollTicking = true;
    }
  }, { passive: true });

  // ── Custom cursor (desktop only) — GPU composited + rAF throttled ──
  const dot = document.getElementById('cursor-dot')!;
  if (!isTouchDevice) {
    let cursorX = -100, cursorY = -100, cursorTick = false;
    document.addEventListener('mousemove', (e) => {
      cursorX = e.clientX;
      cursorY = e.clientY;
      if (!cursorTick) {
        cursorTick = true;
        requestAnimationFrame(() => {
          dot.style.transform = `translate(calc(${cursorX}px - 50%), calc(${cursorY}px - 50%))`;
          cursorTick = false;
        });
      }
    });
  }

  function isClickable(el: Element) {
    const tag = el.tagName.toLowerCase();
    if (tag === 'a' || tag === 'button') return true;
    if (el.hasAttribute('onclick')) return true;
    if (el.getAttribute('role') === 'button') return true;
    let parent = el.parentElement;
    for (let i = 0; i < 4 && parent; i++) {
      if (parent.tagName.toLowerCase() === 'a') return true;
      if (parent.hasAttribute('onclick')) return true;
      if (parent.dataset.youtube || parent.dataset.vimeo) return true;
      parent = parent.parentElement;
    }
    return false;
  }

  document.addEventListener('mouseover', (e) => {
    if (isTouchDevice) return;
    const target = e.target as Element | null;
    dot.classList.toggle('on-link', target ? isClickable(target) : false);
  });

  document.addEventListener('mouseleave', () => { dot.style.opacity = '0'; });
  document.addEventListener('mouseenter', () => { dot.style.opacity = '1'; });

  // ── Magnetic buttons (desktop only) — rAF throttled ──
  if (!isTouchDevice) {
    document.querySelectorAll('.magnetic-btn').forEach((el) => {
    const btn = el as HTMLElement;
    const strength = 0.3;
    let btnTick = false;
    let btnEvt: MouseEvent | null = null;
    let btnRect: DOMRect | null = null;

    btn.addEventListener('mousemove', (e: Event) => {
      btnEvt = e as MouseEvent;
      if (!btnTick) {
        btnTick = true;
        requestAnimationFrame(() => {
          if (!btnEvt) { btnTick = false; return; }
          // Cache rect per frame to avoid layout thrash
          btnRect = btn.getBoundingClientRect();
          const dx = btnEvt.clientX - (btnRect.left + btnRect.width / 2);
          const dy = btnEvt.clientY - (btnRect.top + btnRect.height / 2);
          btn.style.transform = `translate3d(${dx * strength}px, ${dy * strength}px, 0) scale(1.05)`;
          btnTick = false;
          btnEvt = null;
        });
      }
    });

    btn.addEventListener('mouseleave', () => {
      btn.style.transform = 'translate3d(0, 0, 0) scale(1)';
      btn.style.transition = 'transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
      btnRect = null;
    });
  });
  }

  // ── Animated counters ────────────────────────────────
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.countTo || '0', 10);
        const prefix = el.dataset.countPrefix || '';
        if (!target) return;

        let current = 0;
        const duration = 1200;
        const increment = Math.ceil(target / (duration / 16));

        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            current = target;
            clearInterval(timer);
          }
          el.textContent = prefix + current;
        }, 16);

        counterObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('[data-count-to]').forEach(el => counterObserver.observe(el));

  // ── Tilt + glow cards (desktop only, Safari gets glow only) — rAF throttled ──
  if (!isTouchDevice) {
    document.querySelectorAll('.tilt-card, .tilt-only').forEach((el) => {
      const card = el as HTMLElement;
      const maxAngle = parseFloat(card.dataset.tiltMax || '8');
      let tiltTick = false;
      let tiltEvt: MouseEvent | null = null;
      let tiltRect: DOMRect | null = null;

      card.addEventListener('mousemove', (e: Event) => {
        tiltEvt = e as MouseEvent;
        if (!tiltTick) {
          tiltTick = true;
          requestAnimationFrame(() => {
            if (!tiltEvt) { tiltTick = false; return; }
            tiltRect = card.getBoundingClientRect();
            const x = (tiltEvt.clientX - tiltRect.left) / tiltRect.width;
            const y = (tiltEvt.clientY - tiltRect.top) / tiltRect.height;
            card.style.setProperty('--glow-x', `${x * 100}%`);
            card.style.setProperty('--glow-y', `${y * 100}%`);
            if (!isSafari) {
              const rotateX = (y - 0.5) * maxAngle * 2;
              const rotateY = (x - 0.5) * -maxAngle * 2;
              card.style.transform =
                `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
            }
            tiltTick = false;
            tiltEvt = null;
          });
        }
      });

      card.addEventListener('mouseleave', () => {
        if (!isSafari) {
          card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg)';
        }
        tiltRect = null;
      });
    });
  }

  // ── Glow-only cards (desktop only) — rAF throttled ──
  if (!isTouchDevice) {
    document.querySelectorAll('.glow-card').forEach((el) => {
      const card = el as HTMLElement;
      let glowTick = false;
      let glowEvt: MouseEvent | null = null;
      let glowRect: DOMRect | null = null;

      card.addEventListener('mousemove', (e: Event) => {
        glowEvt = e as MouseEvent;
        if (!glowTick) {
          glowTick = true;
          requestAnimationFrame(() => {
            if (!glowEvt) { glowTick = false; return; }
            glowRect = card.getBoundingClientRect();
            const x = (glowEvt.clientX - glowRect.left) / glowRect.width;
            const y = (glowEvt.clientY - glowRect.top) / glowRect.height;
            card.style.setProperty('--glow-x', `${x * 100}%`);
            card.style.setProperty('--glow-y', `${y * 100}%`);
            glowTick = false;
            glowEvt = null;
          });
        }
      });
    });
  }
</script>
