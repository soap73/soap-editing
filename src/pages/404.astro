---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="relative z-10 min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <span class="font-heading text-[12rem] leading-none text-brand-gray-900">404</span>
    <p class="text-brand-gray-400 text-sm mt-2 mb-8">Cette page n'existe pas.</p>
    <a
      href="/"
      class="px-6 py-2 border border-brand-white text-brand-white text-xs uppercase tracking-widest rounded-full hover:bg-brand-white hover:text-brand-black transition-colors"
    >
      Retour à l'accueil
    </a>
  </div>
</BaseLayout>
