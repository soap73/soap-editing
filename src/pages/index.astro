---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../consts';

import Hero from '../components/sections/Hero.astro';
import Projects from '../components/sections/Projects.astro';
import About from '../components/sections/About.astro';
import ClientsBar from '../components/sections/ClientsBar.astro';
import Contact from '../components/sections/Contact.astro';
import Footer from '../components/Footer.astro';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'Soap Edit',
      url: 'https://soap-edit.com',
      description: 'Anthony Vuillerot — Monteur vidéo à Lyon. Montage vidéo professionnel, motion design et sound design. Storytelling visuel pour YouTube, réseaux sociaux et courts-métrages.',
      inLanguage: 'fr',
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: 'https://soap-edit.com/?s={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Person',
      name: 'Anthony Vuillerot',
      alternateName: 'Soap Edit',
      email: site.email,
      url: 'https://soap-edit.com',
      image: 'https://soap-edit.com/og-image.png',
      jobTitle: 'Monteur Vidéo / Motion Designer / Sound Designer',
      sameAs: [site.socials.instagram, site.socials.linkedin],
      knowsAbout: [
        'montage vidéo',
        'motion design',
        'sound design',
        'post-production',
        'étalonnage',
        'Adobe Premiere Pro',
        'DaVinci Resolve',
        'After Effects',
        'YouTube',
        'courts-métrages',
      ],
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Lyon',
        postalCode: '69003',
        addressCountry: 'FR',
      },
    },
    {
      '@type': 'ProfessionalService',
      name: 'Soap Edit',
      url: 'https://soap-edit.com',
      description: 'Monteur vidéo professionnel à Lyon. Services de montage vidéo, motion design et sound design pour YouTube, réseaux sociaux et courts-métrages.',
      provider: { '@type': 'Person', name: 'Anthony Vuillerot' },
      areaServed: {
        '@type': 'City',
        name: 'Lyon',
      },
      makesOffer: [
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'Montage vidéo',
            description: 'Montage vidéo professionnel pour YouTube et réseaux sociaux',
          },
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'Motion design',
            description: 'Création d\'animations graphiques et motion design',
          },
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'Sound design',
            description: 'Design sonore et mixage audio',
          },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Soap Edit | Montage Vidéo, Motion Design & Sound Design"
  description="Anthony Vuillerot — Monteur vidéo à Lyon. Soap Edit : montage vidéo professionnel, motion design et sound design pour YouTube, réseaux sociaux et courts-métrages."
  pageUrl="/"
  schema={schema}
>
  <div class="fixed inset-0 z-0">
    <video
      autoplay
      loop
      muted
      playsinline
      poster="/background-poster.jpg"
      class="absolute inset-0 h-full w-full object-cover blur-[2px] scale-105"
    >
      <source src="/background-wave.webm" type="video/webm" />
      <source src="/background-wave.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-brand-black/60"></div>
  </div>

  <main class="relative z-10 min-h-screen">
    <Hero />
    <Projects />
    <ClientsBar />
    <div class="relative z-10 px-4 md:px-6 pt-24 md:pt-32 pb-20 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <!-- Grille 2 colonnes centrée : About (avec Stack) | Contact -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20">
          <About />
          <Contact />
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
